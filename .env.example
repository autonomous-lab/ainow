# Server
PORT=3040

# llama-server
LLAMA_SERVER_EXE=llama-server         # path to llama-server binary (or just the name if in PATH)
LLAMA_SERVER_PORT=8080                # port for llama-server
MODELS_DIR=~/models                   # base directory for GGUF model files

# LLM (auto-managed by default; set to use an external server)
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=not-needed

# Online mode (no local GPU)
OPENROUTER_API_KEY=your_key           # for -m online

# Browser STT/TTS (default, no server-side processing needed)
BROWSER_STT=1

# Optional: server-side STT (Whisper)
# WHISPER_MODEL=large-v3

# Optional: server-side TTS
# SERVER_TTS=1
# LOCAL_TTS_VOICE=1                   # local Kokoro TTS
# FISH_TTS_URL=http://localhost:8082  # Fish Speech TTS

# Custom models — add any GGUF model by pointing to its directory:
#   MODEL_<ALIAS>=<directory>          (auto-detects .gguf and mmproj files)
#   MODEL_<ALIAS>=<model.gguf>;<mmproj.gguf>;<Display Name>
# Example:
# MODEL_GEMMA=/path/to/gemma-4b-gguf
