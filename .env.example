# Server
PORT=3040

# LLM (any OpenAI-compatible endpoint)
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=not-needed
LLM_MODEL=Qwen3.5-9B-Q4_K_M.gguf

# TTS — set any value to use local Kokoro (no API key needed)
LOCAL_TTS_VOICE=1

# Optional: ElevenLabs TTS (used if LOCAL_TTS_VOICE is not set)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional: Deepgram STT (if not set, uses browser Web Speech API)
DEEPGRAM_API_KEY=

# Optional: Twilio (for phone calls instead of browser)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_PUBLIC_URL=
